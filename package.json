  "name": "exposcalif",
  "version": "1.0.0",
  "description": "Practica Front End Para Calificación De Exposiciones",
  "main": "index.js",
  "scripts": {
  "dev": "concurrently \"npm run dev:backend\" \"npm run dev:frontend\"",
  "dev:backend": "cd backend && npm run dev",
